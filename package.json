{
  "name": "rage2",
  "private": true,
  "workspaces": ["worker", "frontend"],
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "scripts": {
    "dev:worker": "npm -w @rage2/worker run dev",
    "dev:frontend": "npm -w @rage2/frontend run dev",
    "build": "npm -w @rage2/frontend run build && npm -w @rage2/worker run build",
    "deploy": "npm -w @rage2/worker run deploy",
    "db:migrate": "npm -w @rage2/worker run db:migrate"
  }
}
